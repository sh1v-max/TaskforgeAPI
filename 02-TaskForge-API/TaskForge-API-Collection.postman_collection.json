            "url": {
              "raw": "{{BASE_URL}}/api/tasks?status=pending",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "tasks"],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                }
              ]
            }
