        },
        {
          "name": "10. Sort Tasks by Due Date (Ascending)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\n",
                  "    pm.response.to.have.status(200);\n",
                  "});\n",
                  "\n",
                  "pm.test(\"Tasks are sorted by due date\", function () {\n",
                  "    var jsonData = pm.response.json();\n",
                  "    if (jsonData.tasks.length > 1) {\n",
                  "        for (let i = 0; i < jsonData.tasks.length - 1; i++) {\n",
                  "            var current = new Date(jsonData.tasks[i].dueDate).getTime();\n",
                  "            var next = new Date(jsonData.tasks[i + 1].dueDate).getTime();\n",
                  "            pm.expect(current).to.be.lessThan(next);\n",
                  "        }\n",
                  "    }\n",
                  "});\n"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/tasks?sortBy=dueDate:asc",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "tasks"],
              "query": [
                {
                  "key": "sortBy",
                  "value": "dueDate:asc"
                }
              ]
            }
          }
        },
        {
          "name": "11. Pagination - Page 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\n",
                  "    pm.response.to.have.status(200);\n",
                  "});\n",
                  "\n",
                  "pm.test(\"Pagination metadata correct\", function () {\n",
                  "    var jsonData = pm.response.json();\n",
                  "    pm.expect(jsonData.page).to.equal(1);\n",
                  "    pm.expect(jsonData.limit).to.equal(5);\n",
                  "    pm.expect(jsonData.tasks.length).to.be.lessThanOrEq(5);\n",
                  "});\n"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/tasks?page=1&limit=5",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "tasks"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          }
        }
      ]
