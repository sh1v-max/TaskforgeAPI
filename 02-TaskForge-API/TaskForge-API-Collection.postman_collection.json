  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "1. Register - Create New User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Check response status\n",
                  "pm.test(\"Status code is 201\", function () {\n",
                  "    pm.response.to.have.status(201);\n",
                  "});\n",
                  "\n",
                  "// Check response structure\n",
                  "pm.test(\"Response has token\", function () {\n",
                  "    var jsonData = pm.response.json();\n",
                  "    pm.expect(jsonData).to.have.property('token');\n",
                  "    pm.expect(jsonData).to.have.property('user');\n",
                  "    pm.expect(jsonData.user).to.have.property('id');\n",
                  "    pm.expect(jsonData.user).to.have.property('name');\n",
                  "    pm.expect(jsonData.user).to.have.property('email');\n",
                  "});\n",
                  "\n",
                  "// Save token to variable for later use\n",
                  "if (pm.response.code === 201) {\n",
                  "    var jsonData = pm.response.json();\n",
                  "    pm.environment.set(\"JWT_TOKEN\", jsonData.token);\n",
                  "    pm.environment.set(\"USER_ID\", jsonData.user.id);\n",
                  "    console.log(\"✅ Token saved: \" + jsonData.token.substring(0, 20) + \"...\");\n",
                  "}\n"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john{{$timestamp}}@example.com\",\n  \"password\": \"TestPassword123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "2. Login - Get JWT Token",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// This uses the email from the previous registration\n",
                  "// Make sure to run \"Register\" first\n"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Check response status\n",
                  "pm.test(\"Status code is 200\", function () {\n",
                  "    pm.response.to.have.status(200);\n",
                  "});\n",
                  "\n",
                  "// Check response structure\n",
                  "pm.test(\"Login response has token and user\", function () {\n",
                  "    var jsonData = pm.response.json();\n",
                  "    pm.expect(jsonData).to.have.property('token');\n",
                  "    pm.expect(jsonData).to.have.property('user');\n",
                  "    pm.expect(jsonData.message).to.include('Login successful');\n",
                  "});\n",
                  "\n",
                  "// Save token for authenticated requests\n",
                  "if (pm.response.code === 200) {\n",
                  "    var jsonData = pm.response.json();\n",
                  "    pm.environment.set(\"JWT_TOKEN\", jsonData.token);\n",
                  "    pm.environment.set(\"USER_ID\", jsonData.user.id);\n",
                  "    console.log(\"✅ Logged in successfully!\");\n",
                  "}\n"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"TestPassword123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
