{
  "info": {
    "_postman_id": "taskforge-api-collection",
    "name": "TaskForge API",
    "description": "Complete testing collection for TaskForge API\n\nThis collection contains all endpoints organized by feature:\n- Authentication (Register, Login)\n- Task CRUD operations\n- Filtering, Sorting, Pagination\n- Error scenarios\n\nNote: Set JWT_TOKEN variable after login for protected routes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
