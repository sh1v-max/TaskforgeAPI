    {
      "name": "📝 Task CRUD Operations",
      "item": [
        {
          "name": "3. Create Task - Single Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201 Created\", function () {\n",
                  "    pm.response.to.have.status(201);\n",
                  "});\n",
                  "\n",
                  "pm.test(\"Task created with correct fields\", function () {\n",
                  "    var jsonData = pm.response.json();\n",
                  "    pm.expect(jsonData).to.have.property('_id');\n",
                  "    pm.expect(jsonData).to.have.property('title');\n",
                  "    pm.expect(jsonData).to.have.property('status');\n",
                  "    pm.expect(jsonData).to.have.property('user');\n",
                  "    pm.expect(jsonData.title).to.equal('Buy Groceries');\n",
                  "    pm.expect(jsonData.status).to.equal('pending');\n",
                  "});\n",
                  "\n",
                  "// Save task ID for later use\n",
                  "if (pm.response.code === 201) {\n",
                  "    var jsonData = pm.response.json();\n",
                  "    pm.environment.set(\"TASK_ID\", jsonData._id);\n",
                  "    console.log(\"✅ Task created: \" + jsonData._id);\n",
                  "}\n"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy Groceries\",\n  \"description\": \"Milk, eggs, bread, butter\",\n  \"status\": \"pending\",\n  \"dueDate\": \"2026-06-30T23:59:59Z\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/tasks",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "tasks"]
            }
